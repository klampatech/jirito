{
  "name": "jirito",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "build:client": "tsc -p tsconfig.client.json",
    "build:server": "tsc -p tsconfig.server.json",
    "build:tests": "tsc -p tsconfig.tests.json",
    "typecheck": "tsc -b --noEmit",
    "watch:client": "tsc -p tsconfig.client.json --watch",
    "test": "playwright test --config=playwright/playwright.config.mjs",
    "test:unit": "vitest run",
    "server": "node dist/server/server/index.js",
    "dev": "tsx server/index.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "tsx": "^4",
    "typescript": "^5.4",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
