{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": [
      "DOM",
      "ES2022"
    ],
    "outDir": "dist/tests",
    "rootDir": "tests/unit",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
