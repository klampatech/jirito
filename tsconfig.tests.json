{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": [
      "DOM",
      "ES2022"
    ],
    "outDir": "dist/tests",
    "rootDirs": [
      "tests/unit",
      "src",
      "server/routes"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "tests/unit/**/*.ts",
    "src/global.d.ts",
    "server/routes/_shared.ts"
  ]
}
